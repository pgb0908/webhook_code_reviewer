# GitLab 연동 설정
GITLAB_HOST=            # GitLab 서버 주소 (예: gitlab.example.com)

# 프로젝트별 GitLab 토큰 (프로젝트마다 한 줄씩 추가)
# GitLab 프로젝트 ID는 프로젝트 설정 > General에서 확인
PROJECT_TOKEN_123=      # 프로젝트 ID 123의 Personal Access Token (api 권한 필요)
PROJECT_TOKEN_456=      # 프로젝트 ID 456의 Personal Access Token

# LLM 설정
REMOTE_LLM_MODEL=openai/Qwen/Qwen3-Coder-30B-A3B-Instruct  # 기본 모델명 (하위호환)
LLM_CLIENT_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct         # 구조화용 모델명 (vLLM/OpenAI API 기준)
AIDER_MODEL=openai/Qwen/Qwen3-Coder-30B-A3B-Instruct       # aider/litellm용 모델명
REMOTE_LLM_BASE_URL=    # OpenAI 호환 base URL (예: http://localhost:11434/v1 또는 http://host:port)
REMOTE_LLM_API_KEY=dummy                                   # LLM API 키 (불필요 시 dummy 유지)

# 웹훅 서버 설정
LOG_LEVEL=INFO          # DEBUG/INFO/WARNING/ERROR/CRITICAL
SERVER_HOST=0.0.0.0     # 웹훅 수신 IP (0.0.0.0 = 모든 인터페이스)
SERVER_PORT=8000        # 웹훅 수신 포트

# 워크스페이스 설정 (선택)
# WORKSPACE_BASE=/tmp/aider_workspaces  # 임시 작업 디렉토리 경로

# Aider 동작 설정 (선택)
# AIDER_TIMEOUT=600       # Aider 프로세스 최대 실행 시간 (초)
LLM_TIMEOUT=120          # llm-client 구조화 요청 최대 대기 시간 (초)
VALIDATION_COMMAND=      # (선택) push 리뷰 전 검증 명령. 비우면 Maven/Gradle/CMake를 자동 감지
VALIDATION_TIMEOUT=180   # 검증 명령 최대 대기 시간 (초)
MAX_DEEP_REVIEW_UNITS=5  # 한 번의 리뷰에서 deep review할 최대 unit 수
MAX_PARALLEL_REVIEWS=3    # deep review 시 동시에 실행할 aider 요청 수
# COMMENT_MAX_CONTEXT_FILES=3  # comment 응답 시 함께 넘길 최대 파일 수
# COMMENT_EXCLUDE_EXTENSIONS=.sh,.yml,.yaml,.json,.toml,.ini,.conf,.env  # comment 컨텍스트에서 제외할 확장자
# DIFF_IGNORE_PATTERNS=   # 리뷰 제외 파일 패턴 (쉼표 구분, 예: *.sum,dist/*)
# DIFF_OMIT_DELETIONS=true  # 삭제만 있는 hunk를 리뷰 대상에서 제외할지 여부

# 봇 설정 (선택)
# BOT_USERNAME=           # 봇 GitLab 계정명 (설정 시 봇 자신의 멘션 무시)
