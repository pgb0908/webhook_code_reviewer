# GitLab 연동 설정
GITLAB_HOST=            # GitLab 서버 주소 (예: gitlab.example.com)

# 프로젝트별 GitLab 토큰 (프로젝트마다 한 줄씩 추가)
# GitLab 프로젝트 ID는 프로젝트 설정 > General에서 확인
PROJECT_TOKEN_123=      # 프로젝트 ID 123의 Personal Access Token (api 권한 필요)
PROJECT_TOKEN_456=      # 프로젝트 ID 456의 Personal Access Token

# LLM 설정
REMOTE_LLM_MODEL=openai/Qwen/Qwen3-Coder-30B-A3B-Instruct  # 사용할 모델명
REMOTE_LLM_BASE_URL=    # LLM API 엔드포인트 URL
REMOTE_LLM_API_KEY="dummy-token"                            # LLM API 키 (불필요 시 dummy 유지)

# 웹훅 서버 설정
SERVER_HOST=0.0.0.0     # 웹훅 수신 IP (0.0.0.0 = 모든 인터페이스)
SERVER_PORT=8000        # 웹훅 수신 포트

# 워크스페이스 설정 (선택)
# WORKSPACE_BASE=/tmp/aider_workspaces  # 임시 작업 디렉토리 경로

# Aider 동작 설정 (선택)
# AIDER_TIMEOUT=600       # Aider 프로세스 최대 실행 시간 (초)
# DIFF_MAX_CHARS=10000    # 단일 청크 최대 diff 크기 (초과 시 청크 분할)
# DIFF_IGNORE_PATTERNS=   # 리뷰 제외 파일 패턴 (쉼표 구분, 예: *.sum,dist/*)
# DIFF_OMIT_DELETIONS=true  # 삭제 전용 hunk 제거 여부

# 봇 설정 (선택)
# BOT_USERNAME=           # 봇 GitLab 계정명 (설정 시 봇 자신의 멘션 무시)
